{
  "expo": {
    "name": "Mon Argent",
    "slug": "Mon_argent",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/mon_argent_logo.png",
    "scheme": "monargent",
    "splash": {
      "image": "./assets/splashscreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/b55b101f-7b0a-4d76-84d9-c99c36d16f83"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.monargent.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/mon_argent_logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-router",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b55b101f-7b0a-4d76-84d9-c99c36d16f83"
      }
    },
    "owner": "tsitsito"
  }
}
